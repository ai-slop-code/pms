# Copy to .env and fill in real values. NEVER commit the populated file.

# Public hostname served by Caddy. Used for automatic TLS and CORS.
PMS_DOMAIN=pms.example.com
CORS_ORIGINS=https://pms.example.com

# Frontend → backend wiring (consumed by the pms-frontend container at start).
#
# Leave empty for the default same-origin compose layout (Caddy → nginx →
# pms-backend, all under PMS_DOMAIN). Set to an absolute URL when you front
# the API with a different hostname, e.g.
#   PMS_API_BASE_URL=https://api.example.com
# In cross-origin mode you must also set CORS_ORIGINS to the SPA's origin
# and PMS_COOKIE_SAMESITE=none / PMS_COOKIE_SECURE=true on the backend.
PMS_API_BASE_URL=

# 32-byte hex/base64 secret used to sign session cookies. Generate with:
#   openssl rand -hex 32
SESSION_SECRET=replace-me-32-bytes-hex

# 32-byte key for field-level DB encryption. Generate with:
#   openssl rand -base64 32
DB_ENCRYPTION_KEY=replace-me-base64

# Bootstrap account (only used on very first startup; must be ≥12 chars).
FIRST_SUPERADMIN_EMAIL=admin@example.com
FIRST_SUPERADMIN_PASSWORD=change-me-please-12

# Observability
SENTRY_DSN=
LOG_LEVEL=info
AUDIT_LOG_RETENTION_DAYS=365

# OpenTelemetry (traces). Leave empty to disable.
# Examples:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
#   OTEL_EXPORTER_OTLP_PROTOCOL=grpc            # or http/protobuf
#   OTEL_TRACES_SAMPLER_ARG=0.1                 # 10% head sampling
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_SAMPLER_ARG=0.1

# TOTP / 2FA (per-user opt-in, recovery codes generated on enrolment)
PMS_2FA_ISSUER=PMS
# Dev-only escape hatch: skip the TOTP challenge for enrolled users.
# Rejected at startup unless PMS_ENV ∈ {dev,development,test}.
PMS_2FA_DEV_BYPASS=false

# Trust X-Forwarded-For / X-Real-IP from the reverse proxy in front of the
# backend. The compose stack puts Caddy → nginx → backend, so this is
# always true in that topology. Set to false if exposing the backend
# directly to untrusted networks (per-IP rate limiting will then key on
# the immediate TCP peer).
PMS_TRUSTED_PROXY=true

# Integrations (leave empty to disable)
NUKI_API_TOKEN=
