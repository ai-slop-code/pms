# Frontend build-time configuration. Copy to `.env.local` (ignored by git) or
# pass at build time via `VITE_API_BASE_URL=... npm run build`.

# Base URL for backend API requests.
# - Empty (default): same-origin deploy; the reverse proxy routes /api/* to the
#   backend on the same host the SPA is served from.
# - Absolute URL: cross-origin deploy. Example:
#     VITE_API_BASE_URL=https://api.pms.airport.sk
#   Requirements in that mode:
#     * Backend must set CORS_ORIGINS to include the SPA's origin
#       (e.g. CORS_ORIGINS=https://pms.airport.sk).
#     * Session cookie must be SameSite=None; Secure — both origins on HTTPS.
VITE_API_BASE_URL=
