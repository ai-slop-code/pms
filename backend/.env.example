# HTTP listen address
HTTP_ADDR=:8080

# SQLite file path (directory is created automatically)
DATABASE_PATH=./data/pms.db

# First super_admin when database is empty (omit after bootstrap)
FIRST_SUPERADMIN_EMAIL=admin@example.com
FIRST_SUPERADMIN_PASSWORD=change-me

# Browser origin(s) for CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Deployment environment label (production|dev|test). Controls secure defaults.
# `dev` / `test` flip the session cookie to Secure=false so the app works on
# plain HTTP during local development.
PMS_ENV=production

# Override auth-cookie Secure/SameSite explicitly. SameSite=None requires
# Secure=true. If unset, Secure defaults to true unless PMS_ENV is dev/test.
# PMS_COOKIE_SECURE=true
# PMS_COOKIE_SAMESITE=lax  # one of: lax|strict|none

# Session lifetime
SESSION_TTL_HOURS=168

# How often to run ICS sync for all properties with a configured URL (minutes)
OCCUPANCY_SYNC_INTERVAL_MINUTES=60

# Nuki API integration (set credentials per property in UI)
NUKI_API_BASE_URL=https://api.nuki.io
NUKI_HTTP_TIMEOUT_SECONDS=15
NUKI_MOCK_MODE=false

# How often expired Nuki codes are moved to historical state (minutes)
NUKI_CLEANUP_INTERVAL_MINUTES=1440

# Prometheus metrics gating. In production at least one of these is required:
#   PMS_METRICS_TOKEN  — Bearer token required on /metrics on the main listener.
#   PMS_METRICS_BIND   — Loopback or internal bind (e.g. 127.0.0.1:9090).
# Setting PMS_METRICS_BIND removes /metrics from the public listener.
PMS_METRICS_TOKEN=
PMS_METRICS_BIND=

# Master key for at-rest encryption of property secrets and generated PINs.
# Required in production. Must decode to exactly 32 bytes — generate with:
#   openssl rand -base64 32
# Rotating this key invalidates every existing encrypted row, so treat it as
# immutable after first use (or plan a re-encryption window).
PMS_MASTER_KEY=

# Automated database snapshots (VACUUM INTO). Disabled when interval is 0.
# Retention: 24 most-recent hourly + one per day for 7 days. Off-host copy
# (rsync/rclone) is the operator's responsibility — see
# docs/deployment/backup-runbook.md.
PMS_BACKUP_INTERVAL_MINUTES=60
PMS_BACKUP_DIR=
